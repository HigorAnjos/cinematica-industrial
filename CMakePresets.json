    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "x64 Debug (vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "C:/Users/higor/scoop/apps/vcpkg/current/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "release",
            "displayName": "x64 Release (vcpkg)",
            "inherits": "default",
            "cacheVariables": {
